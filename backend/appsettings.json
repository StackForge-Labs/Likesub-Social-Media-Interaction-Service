{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Redis": {
    "Enabled": true,
    "Host": "redis",
    "Port": 6379,
    "Password": "likesub_redis_pass",
    "Database": 0,
    "InstancePrefix": "likesub:prod",
    "DefaultTtlSeconds": 300,
    "ConnectTimeoutMs": 5000,
    "SyncTimeoutMs": 5000,
    "ConnectRetry": 3,
    "AbortOnConnectFail": false,
    "AllowAdmin": true,
    "Ssl": false
  },
  "AllowedHosts": "*"
}
