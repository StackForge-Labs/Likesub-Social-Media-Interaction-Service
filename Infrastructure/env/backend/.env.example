# Backend host runtime env template (non-container execution).
# For container-based execution, use compose files and/or injected env variables.

# ASPNETCORE_ENVIRONMENT=Development
# Http__EnforceHttps=false
# Database__ConnectionString=server=localhost;port=3306;database=Likesub_Social_Media_Interaction;user=likesub;password=likesub_pass;
