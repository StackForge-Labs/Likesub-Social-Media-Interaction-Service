{
  "name": "social-network-service-management-system",
  "version": "1.0.0",
  "description": "**Edunext .NET** - Hệ thống quản lý mạng xã hội giáo dục được xây dựng theo kiến trúc microservices với .NET 8 và Next.js.",
  "scripts": {
    "//": "********************* DEVELOPMENT *********************",
    "setup:dev": "node container/scripts/setup-env.js",
    "dev": "npm run setup:dev && docker compose -p snms -f container/compose/docker-compose.dev.yml up",
    "dev:up": "docker compose -p likesub -f container/compose/docker-compose.dev.yml up -d",
    "dev:down": "docker compose -p likesub -f container/compose/docker-compose.dev.yml down",
    "dev:build": "docker compose -p likesub -f container/compose/docker-compose.dev.yml up --build",
    "dev:rebuild": "docker compose -p likesub -f container/compose/docker-compose.dev.yml up --build -d",
    "dev:stop": "docker compose -p likesub -f container/compose/docker-compose.dev.yml stop",
    "dev:restart": "docker compose -p likesub -f container/compose/docker-compose.dev.yml restart",
    "dev:pull": "docker compose -p likesub -f container/compose/docker-compose.dev.yml pull",
    "dev:ps": "docker compose -p likesub -f container/compose/docker-compose.dev.yml ps",
    
    "//": "********************* SERVICE SHELL *********************",
    "dev:backend": "docker exec -it likesub-backend-dev sh",
    "dev:redis": "docker exec -it likesub-redis-dev redis-cli",
    
    "//": "********************* LOGS *********************",
    "dev:logs": "docker compose -p likesub -f container/compose/docker-compose.dev.yml logs -f --tail=200",
    "dev:log:backend": "docker compose -p likesub -f container/compose/docker-compose.dev.yml logs -f backend",

    "//": "********************* DOCKER UTILITIES *********************",
    "docker:ps": "docker ps -a",
    "docker:stop-all": "docker stop $(docker ps -aq) || true",
    "docker:rm-all": "docker rm -f $(docker ps -aq) || true",
    "docker:prune": "docker system prune -af --volumes",
    "docker:images": "docker images",
    "docker:rmi-unused": "docker image prune -a -f",
    "docker:volume-list": "docker volume ls",
    "docker:volume-prune": "docker volume prune -f",
    "docker:network-list": "docker network ls",
    "docker:network-prune": "docker network prune -f",
    "docker:reset": "npm run docker:stop-all && npm run docker:rm-all && npm run docker:prune",
    "docker:clean-cache": "docker builder prune -af",
    
    "//": "********************* BUILD & SYNC *********************",
    "sync": "git pull && npm run dev:pull && npm run dev:build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aptech-Eproject/Likesub-Social-Media-Interaction-Service.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Aptech-Eproject/Likesub-Social-Media-Interaction-Service/issues"
  },
  "homepage": "https://github.com/Aptech-Eproject/Likesub-Social-Media-Interaction-Service#readme"
}
